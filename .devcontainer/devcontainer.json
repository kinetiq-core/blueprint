// Optional Dev Container for blueprint (@kinetiq-core/blueprint).
//
// Standalone CLI tool (tsx/TypeScript); no web server, no database, no
// sibling-repo mounts (blueprint does not consume kinetiq-specs). No
// forwarded ports — if a server is ever added later, pick a port well
// outside the kinetiq web stacks' 43xx range.
//
// Preferred daily workflow is VS Code opened through WSL and commands run on
// the WSL host. This container is only for isolated/reproducible toolchain work.
{
  "name": "blueprint",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/kinetiq-core/blueprint",
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "openai.chatgpt"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  // Warn (non-blocking) if the repo wasn't cloned under kinetiq-core/ —
  // sibling repos won't be visible under /workspaces/kinetiq-core/ and
  // cross-repo references will silently break.
  "postCreateCommand": "test -d /workspaces/kinetiq-core/kinetiq-specs || echo '[WARN] kinetiq-specs not found alongside this repo. Parent dir should be kinetiq-core/ — see kinetiq-workspace/README.md'; npm install"
}
